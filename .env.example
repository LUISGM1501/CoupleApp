VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Solo para GitHub Pages en modo "repo" (no custom domain). Ej: /nosotros/
VITE_BASE_PATH=/

# Modo preview sin Supabase — arranca con datos falsos para probar diseño/flujos.
# Dejá en "false" (o sin la linea) para uso normal. Poné "true" SOLO local.
VITE_MOCK=false
